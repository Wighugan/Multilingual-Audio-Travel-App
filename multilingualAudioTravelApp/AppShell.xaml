<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="multilingualAudioTravelApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:multilingualAudioTravelApp"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Trang Chủ" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate local:HomePage}" Route="HomePage" />
        </Tab>

        <Tab Title="Bản Đồ" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
        </Tab>
    </TabBar>

</Shell>
