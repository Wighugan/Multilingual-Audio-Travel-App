<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="multilingualAudioTravelApp.PremiumPage">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <Label x:Name="PremiumMainTitle" Text="" FontSize="28"
                   FontAttributes="Bold" HorizontalOptions="Center"/>

            <!-- Bảng so sánh tính năng -->
            <Frame  CornerRadius="16" Padding="0"
       BorderColor="#E0E0E0" HasShadow="False">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
          ColumnDefinitions="*,80,80">

                    <!-- Header -->
                    <Label Grid.Row="0" Grid.Column="0" x:Name="FeaturesLabel" Text=""
               FontSize="13" TextColor="Black" FontAttributes="Bold" Padding="16,12"/>
                    <Label Grid.Row="0" Grid.Column="1" x:Name="FreeLabel" Text=""
               FontSize="13" TextColor="Black" HorizontalOptions="Center" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label Grid.Row="0" Grid.Column="2" x:Name="PaidLabel" Text=""
               FontSize="13" TextColor="Black" FontAttributes="Bold"
               HorizontalOptions="Center" VerticalOptions="Center"/>

                    <!-- Dòng 1 -->
                    <Label Grid.Row="1" Grid.Column="0"
               x:Name="Feature1Label" Text=""
               FontSize="13" Padding="16,14" LineBreakMode="WordWrap"/>
                    <Label Grid.Row="1" Grid.Column="1" Text="✔" TextColor="#1D9E75"
               HorizontalOptions="Center" VerticalOptions="Center" FontSize="16"/>
                    <Label Grid.Row="1" Grid.Column="2" Text="✔" TextColor="#1D9E75"
               HorizontalOptions="Center" VerticalOptions="Center" FontSize="16"/>

                    <!-- Dòng 2 -->
                    <Label Grid.Row="2" Grid.Column="0"
               x:Name="Feature2Label" Text=""
               FontSize="13" Padding="16,14" LineBreakMode="WordWrap"/>
                    <Label Grid.Row="2" Grid.Column="2" Text="✔" TextColor="#1D9E75"
               HorizontalOptions="Center" VerticalOptions="Center" FontSize="16"/>

                    <!-- Dòng 3 -->
                    <Label Grid.Row="3" Grid.Column="0"
               x:Name="Feature3Label" Text=""
               FontSize="13" Padding="16,14" LineBreakMode="WordWrap"/>
                    <Label Grid.Row="3" Grid.Column="2" Text="✔" TextColor="#1D9E75"
               HorizontalOptions="Center" VerticalOptions="Center" FontSize="16"/>

                    <!-- Dòng 4 -->
                    <Label Grid.Row="4" Grid.Column="0"
               x:Name="Feature4Label" Text=""
               FontSize="13" Padding="16,14" LineBreakMode="WordWrap"/>
                    <Label Grid.Row="4" Grid.Column="2" Text="✔" TextColor="#1D9E75"
               HorizontalOptions="Center" VerticalOptions="Center" FontSize="16"/>
                </Grid>
            </Frame>

            <!-- Chọn gói giá -->
            <VerticalStackLayout Spacing="10">

                <!-- Theo năm -->
                <Border x:Name="BorderNam" 
            Stroke="#E0E0E0" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPlanSelected" CommandParameter="nam"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                        <Ellipse x:Name="RadioNam" WidthRequest="22" HeightRequest="22"
                     Stroke="#CCCCCC" StrokeThickness="1.5"
                     Fill="White" VerticalOptions="Center"/>
                        <Label Grid.Column="1" x:Name="PlanYearLabel" Text=""
                   FontSize="15" VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Label Grid.Column="2" Text="330.000 VND"
                   FontSize="15" TextColor="Black" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Theo tháng -->
                <Border x:Name="BorderThang" 
            Stroke="#E0E0E0" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPlanSelected" CommandParameter="thang"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                        <Ellipse x:Name="RadioThang" WidthRequest="22" HeightRequest="22"
                     Stroke="#CCCCCC" StrokeThickness="1.5"
                     Fill="White" VerticalOptions="Center"/>
                        <Label Grid.Column="1" x:Name="PlanMonthLabel" Text=""
                   FontSize="15" VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Label Grid.Column="2" Text="101.000 VND"
                   FontSize="15" TextColor="Black" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Theo tuần -->
                <Border x:Name="BorderTuan" 
            Stroke="#E0E0E0" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPlanSelected" CommandParameter="tuan"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                        <Ellipse x:Name="RadioTuan" WidthRequest="22" HeightRequest="22"
                     Stroke="#CCCCCC" StrokeThickness="1.5"
                     Fill="White" VerticalOptions="Center"/>
                        <Label Grid.Column="1" x:Name="PlanWeekLabel" Text=""
                   FontSize="15" VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Label Grid.Column="2" Text="51.000 VND"
                   FontSize="15" TextColor="Black" VerticalOptions="Center"/>
                    </Grid>
                </Border>

            </VerticalStackLayout>

            <Button x:Name="BuyButton"
                    Text=""
                    BackgroundColor="Blue"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="54"
                    Clicked="OnBuyClicked"/>

            <Label x:Name="StatusLabel" Text=""
                   HorizontalOptions="Center" TextColor="Green" FontSize="14"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>