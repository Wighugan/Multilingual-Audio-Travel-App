<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
    xmlns:loc="clr-namespace:multilingualAudioTravelApp.Languages"
    x:Class="multilingualAudioTravelApp.QRScanPage"
    Title="{x:Static loc:AppStrings.ScanQR}"
    BackgroundColor="Black">

    <Grid>

        <!-- Camera quét QR -->
        <zxing:CameraBarcodeReaderView
            x:Name="BarcodeReader"
            CameraLocation="Rear"
            BarcodesDetected="OnBarcodeDetected">

        </zxing:CameraBarcodeReaderView>

        <!-- Khung ngắm QR ở giữa màn hình -->
        <Border
            WidthRequest="240"
            HeightRequest="240"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            BackgroundColor="Transparent"
            Stroke="White"
            StrokeThickness="2">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <BoxView BackgroundColor="Transparent"/>
        </Border>

        <!-- Label trạng thái ở giữa phía trên khung -->
        <Label
            x:Name="StatusLabel"
            Text="Hướng camera vào mã QR"
            TextColor="White"
            FontSize="14"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Margin="0,-180,0,0"
            BackgroundColor="#80000000"
            Padding="12,6"/>

        <!-- Nút Đóng phía dưới -->
        <Button
            Text="✕  Đóng"
            BackgroundColor="#80000000"
            TextColor="White"
            CornerRadius="10"
            WidthRequest="160"
            HorizontalOptions="Center"
            VerticalOptions="End"
            Margin="0,0,0,50"
            Clicked="OnCloseClicked"/>

        <!-- POPUP kết quả quét -->
        <Grid
            x:Name="ResultPopupOverlay"
            IsVisible="False"
            BackgroundColor="#80000000">
            <Frame
                BackgroundColor="White"
                CornerRadius="20"
                Padding="15"
                Margin="30"
                VerticalOptions="Center"
                HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label
                        x:Name="ResultPopupTitle"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="Black" />

                    <Label
                        x:Name="ResultPopupDescription"
                        FontSize="14"
                        TextColor="Gray" />

                    <HorizontalStackLayout Spacing="20" HorizontalOptions="Center" Padding="10">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                            <ImageButton
                                x:Name="ResultPlayStopButton"
                                Source="play_icon.png"
                                WidthRequest="60"
                                HeightRequest="60"
                                CornerRadius="30"
                                Padding="15"
                                Aspect="AspectFit"
                                Clicked="OnResultPlayClicked"
                                BackgroundColor="#E0E0E0" />
                            <Label Text="{x:Static loc:AppStrings.Play}" FontSize="11" TextColor="Gray" HorizontalOptions="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                            <ImageButton
                                Source="close_icon.png"
                                WidthRequest="60"
                                HeightRequest="60"
                                CornerRadius="30"
                                Padding="15"
                                Aspect="AspectFit"
                                Clicked="OnResultCloseClicked"
                                BackgroundColor="#FFE0E0" />
                            <Label Text="{x:Static loc:AppStrings.Close}" FontSize="11" TextColor="Gray" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- POPUP KẾT QUẢ QUÉT QR PREMIUM -->
        <Grid x:Name="PremiumPopupOverlay"
              IsVisible="False"
              BackgroundColor="#80000000"
              ZIndex="999">
            <Frame BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                   CornerRadius="20" Padding="20"
                   Margin="30" VerticalOptions="Center" HasShadow="True">
                <VerticalStackLayout Spacing="14">

                    <!-- Icon + Tiêu đề -->
                    <Label Text="⭐" FontSize="40" HorizontalOptions="Center"/>
                    <Label x:Name="PremiumPopupTitle"
                           FontSize="18" FontAttributes="Bold"
                           HorizontalOptions="Center"/>

                    <!-- Thông tin -->
                    <Frame CornerRadius="12" Padding="14"
                           HasShadow="False" BorderColor="#E0E0E0">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{x:Static loc:AppStrings.Email}" FontSize="13" TextColor="Gray"/>
                                <Label x:Name="PremiumEmailLabel"
                                       Grid.Column="1" FontSize="13" FontAttributes="Bold"/>
                            </Grid>
                            <BoxView HeightRequest="0.5" BackgroundColor="#E0E0E0"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{x:Static loc:AppStrings.ExpiryLabel}" FontSize="13" TextColor="Gray"/>
                                <Label x:Name="PremiumExpiryLabel"
                                       Grid.Column="1" FontSize="13" FontAttributes="Bold"/>
                            </Grid>
                            <BoxView HeightRequest="0.5" BackgroundColor="#E0E0E0"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{x:Static loc:AppStrings.StatusLabel}" FontSize="13" TextColor="Gray"/>
                                <Label x:Name="PremiumStatusLabel"
                                       Grid.Column="1" FontSize="13" FontAttributes="Bold"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Nút đóng -->
                    <Button Text="Đóng"
                            BackgroundColor="#E0E0E0"
                            TextColor="#333333"
                            CornerRadius="12"
                            HeightRequest="46"
                            Clicked="OnPremiumPopupCloseClicked"/>

                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- POPUP DANH SÁCH QUÁN PREMIUM (nằm ngoài, ngang hàng root) -->
        <Grid x:Name="PremiumListOverlay"
              IsVisible="False"
              BackgroundColor="#80000000"
              ZIndex="999">
            <Frame BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                   CornerRadius="20" Padding="0"
                   Margin="20" VerticalOptions="Center"
                   HasShadow="True" HeightRequest="520">
                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Header -->
                    <VerticalStackLayout Grid.Row="0" Padding="20,16" Spacing="4">
                    <Label Text="{x:Static loc:AppStrings.PremiumListTitle}"
                               FontSize="17" FontAttributes="Bold"/>
                        <Label Text="{x:Static loc:AppStrings.PremiumListSubtitle}"
                               FontSize="12" TextColor="Gray"/>
                    </VerticalStackLayout>
                    <BoxView Grid.Row="0" VerticalOptions="End"
                             HeightRequest="0.5" BackgroundColor="#E0E0E0"/>

                    <!-- Danh sách quán -->
                    <CollectionView Grid.Row="1"
                                    x:Name="PremiumPoiList"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="80,*" HeightRequest="80">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="OnPremiumPoiTapped"
                                            CommandParameter="{Binding .}"/>
                                    </Grid.GestureRecognizers>
                                    <Image Grid.Column="0"
                                           Source="{Binding FullImageUrl}"
                                           Aspect="AspectFill"
                                           HeightRequest="80" WidthRequest="80"
                                           InputTransparent="True"/>
                                    <VerticalStackLayout Grid.Column="1"
                                                         Padding="12,10" Spacing="4"
                                                         VerticalOptions="Center"
                                                         InputTransparent="True">
                                        <Label Text="{Binding CurrentName}"
                                               FontSize="14" FontAttributes="Bold"
                                               MaxLines="1" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding CurrentDescription}"
                                               FontSize="12" TextColor="Gray"
                                               MaxLines="2" LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>
                                    <BoxView Grid.ColumnSpan="2" VerticalOptions="End"
                                             HeightRequest="0.5" BackgroundColor="#E0E0E0"
                                             InputTransparent="True"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Popup nghe thuyết minh (chồng lên list) -->
                    <Grid Grid.Row="1"
                          x:Name="PremiumSpeakOverlay"
                          IsVisible="False"
                          BackgroundColor="#80000000"
                          ZIndex="99">
                        <Frame BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                               CornerRadius="16" Padding="20"
                               Margin="16" VerticalOptions="Center">
                            <VerticalStackLayout Spacing="12">
                                <Label x:Name="PremiumSpeakTitle"
                                       FontSize="17" FontAttributes="Bold"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="PremiumSpeakDesc"
                                       FontSize="13" TextColor="Gray"
                                       MaxLines="4" LineBreakMode="WordWrap"/>
                                <HorizontalStackLayout Spacing="16"
                                                       HorizontalOptions="Center" Padding="8">
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                        <ImageButton x:Name="PremiumPlayBtn"
                                                     Source="play_icon.png"
                                                     WidthRequest="56" HeightRequest="56"
                                                     CornerRadius="28" Padding="14"
                                                     BackgroundColor="#E0E0E0"
                                                     Clicked="OnPremiumPlayClicked"/>
                                        <Label Text="{x:Static loc:AppStrings.Play}" FontSize="11"
                                               TextColor="Gray" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                        <ImageButton Source="close_icon.png"
                                                     WidthRequest="56" HeightRequest="56"
                                                     CornerRadius="28" Padding="14"
                                                     BackgroundColor="#FFE0E0"
                                                     Clicked="OnPremiumSpeakCloseClicked"/>
                                        <Label Text="{x:Static loc:AppStrings.Close}" FontSize="11"
                                               TextColor="Gray" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <!-- Nút đóng danh sách -->
                    <Button Grid.Row="2" Text="Đóng"
                            BackgroundColor="#EEEEEE" TextColor="#333333"
                            CornerRadius="0" HeightRequest="50"
                            Clicked="OnPremiumListCloseClicked"/>
                </Grid>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>
