<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="multilingualAudioTravelApp.LoginPage"
    NavigationPage.HasBackButton="False"
    Shell.NavBarIsVisible="False"
    xmlns:lang="clr-namespace:multilingualAudioTravelApp.Languages"
    Title= "{x:Static lang:AppStrings.LogIn}">

    <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">

        <Label Text="{x:Static lang:AppStrings.LogIn}" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>

        <Entry x:Name="EmailEntry" Placeholder="{x:Static lang:AppStrings.Email}" Keyboard="Email"/>

        <Entry x:Name="PasswordEntry" Placeholder="{x:Static lang:AppStrings.Pass}" IsPassword="True"/>

        <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False" HorizontalOptions="Center"/>

        <Button Text="{x:Static lang:AppStrings.LogIn}" CornerRadius="10" HeightRequest="48" Clicked="OnLoginClicked"/>

        <Button
        Text="{x:Static lang:AppStrings.AskRegis}"
        BackgroundColor="Transparent"
        TextColor="Gray"
        Clicked="OnGoToRegisterClicked"/>

    </VerticalStackLayout>
</ContentPage>
