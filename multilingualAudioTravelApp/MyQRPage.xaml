<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             xmlns:loc="clr-namespace:multilingualAudioTravelApp.Languages"
             x:Class="multilingualAudioTravelApp.MyQRPage">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20" VerticalOptions="Center">
         <!-- Thông tin gói -->
            <Frame CornerRadius="16" Padding="16"
                   HasShadow="False" BorderColor="#E0E0E0">
                <VerticalStackLayout Spacing="8">

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{x:Static loc:AppStrings.Email}" FontSize="13" TextColor="Gray"/>
                        <Label x:Name="EmailLabel" Grid.Column="1"
                               FontSize="13" FontAttributes="Bold"/>
                    </Grid>

                    <BoxView HeightRequest="0.5" BackgroundColor="#E0E0E0"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="MyQRExpiryLabel" Text="" FontSize="13" TextColor="Gray"/>
                        <Label x:Name="ExpiryLabel" Grid.Column="1"
                               FontSize="13" FontAttributes="Bold" TextColor="#1D9E75"/>
                    </Grid>

                    <BoxView HeightRequest="0.5" BackgroundColor="#E0E0E0"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="MyQRStatusLabel" Text="" FontSize="13" TextColor="Gray"/>
                        <Label x:Name="StatusLabel" Grid.Column="1"
                               FontSize="13" FontAttributes="Bold"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- Nút gia hạn -->
            <Button x:Name="RenewButton"
                    Text=""
                    BackgroundColor="#FF6F00"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="50"
                    IsVisible="False"
                    Clicked="OnRenewClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>