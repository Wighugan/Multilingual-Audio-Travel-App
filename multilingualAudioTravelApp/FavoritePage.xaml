<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="multilingualAudioTravelApp.FavoritePage"
    xmlns:lang="clr-namespace:multilingualAudioTravelApp.Languages"
    Title="{x:Static lang:AppStrings.Favorite}">

    <!-- Root Grid: list + popup xếp chồng -->
    <Grid>

        <!-- ── DANH SÁCH YÊU THÍCH ── -->
        <CollectionView
            x:Name="FavCollection"
            Margin="12"
            SelectionMode="None">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                    <Label Text="" FontSize="60" HorizontalOptions="Center"/>
                    <Label Text="{x:Static lang:AppStrings.NotSaveRes}"
                           FontSize="20" TextColor="Gray" HorizontalOptions="Center"/>
                    <Label Text="{x:Static lang:AppStrings.PressHeart}"
                           FontSize="13" TextColor="Gray" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,6" CornerRadius="16" HasShadow="False" Padding="0"
                           BackgroundColor="White">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFavoriteRowTapped" CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>

                        <Grid ColumnDefinitions="*,Auto" HeightRequest="100">

                            <!-- Ảnh + Tên -->
                            <Grid Grid.Column="0" ColumnDefinitions="120,*" ColumnSpacing="0">

                                <Image
                                    Grid.Column="0"
                                    Source="{Binding PoiImage}"
                                    Aspect="AspectFill"
                                    HeightRequest="100"
                                    WidthRequest="120"
                                    VerticalOptions="Fill"
                                    InputTransparent="True"/>

                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Padding="12,10"
                                    Spacing="4"
                                    VerticalOptions="Center"
                                    InputTransparent="True">
                                    <Label
                                        Text="{Binding PoiName}"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        MaxLines="1"
                                        LineBreakMode="TailTruncation"/>
                                    <Label
                                        Text="{Binding PoiDescription}"
                                        FontSize="12"
                                        TextColor="Gray"
                                        MaxLines="2"
                                        LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Nút Bỏ lưu -->
                            <Border
                                Grid.Column="1"
                                BackgroundColor="#FFF0F0"
                                StrokeThickness="0"
                                Margin="8"
                                Padding="10,6"
                                VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnRemoveFavoriteTapped" CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Label
                                    Text="{x:Static lang:AppStrings.Unsave}"
                                    TextColor="#E53935"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                            </Border>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- ── POPUP THUYẾT MINH ── -->
        <Grid x:Name="FavPopupOverlay" IsVisible="False" BackgroundColor="#80000000"
      ZIndex="999" InputTransparent="False">
            <Frame BackgroundColor="White" CornerRadius="20" Padding="15"
                   Margin="20" VerticalOptions="Center" HasShadow="True">

                <VerticalStackLayout Spacing="10">

                    <!-- Carousel ảnh -->
                    <Grid HeightRequest="200">
                        <CarouselView x:Name="FavPopupCarousel"
                                      IndicatorView="{x:Reference favIndicatorView}">
                            <CarouselView.ItemTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding .}" Aspect="AspectFill"/>
                                </DataTemplate>
                            </CarouselView.ItemTemplate>
                        </CarouselView>

                        <IndicatorView x:Name="favIndicatorView"
                                       IndicatorsShape="Circle"
                                       IndicatorColor="#D3D3D3"
                                       SelectedIndicatorColor="#1D9E75"
                                       HorizontalOptions="Center"
                                       VerticalOptions="End"
                                       Margin="0,0,0,10"/>
                    </Grid>

                    <!-- Tên quán -->
                    <Label x:Name="FavPopupTitle"
                           FontSize="20" FontAttributes="Bold" TextColor="Black"/>

                    <!-- Mô tả -->
                    <Label x:Name="FavPopupDescription"
                           FontSize="14" TextColor="Gray"/>

                    <!-- Các nút -->
                    <HorizontalStackLayout Spacing="20" HorizontalOptions="Center" Padding="10">

                        <!-- Nghe thuyết minh -->
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                            <ImageButton x:Name="FavPlayStopButton"
                                         Source="play_icon.png"
                                         WidthRequest="60" HeightRequest="60"
                                         CornerRadius="30" Padding="15" Aspect="AspectFit"
                                         Clicked="OnFavPopupPlayClicked"
                                         BackgroundColor="#E0E0E0"/>
                            <Label x:Name="FavPlayLabel" Text="{x:Static lang:AppStrings.Play}"
                                   FontSize="11" TextColor="Gray" HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Bản đồ -->
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                            <ImageButton Source="map.png"
                                         WidthRequest="60" HeightRequest="60"
                                         CornerRadius="30" Padding="15" Aspect="AspectFit"
                                         Clicked="OnFavPopupMapClicked"
                                         BackgroundColor="#E8F5E9"/>
                            <Label x:Name="FavMapLabel" Text="{x:Static lang:AppStrings.Map}"
                                   FontSize="11" TextColor="Gray" HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Đóng -->
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                            <ImageButton Source="close_icon.png"
                                         WidthRequest="60" HeightRequest="60"
                                         CornerRadius="30" Padding="15" Aspect="AspectFit"
                                         Clicked="OnFavPopupCloseClicked"
                                         BackgroundColor="#FFE0E0"/>
                            <Label x:Name="FavCloseLabel" Text="{x:Static lang:AppStrings.Close}"
                                   FontSize="11" TextColor="Gray" HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>
