<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="multilingualAudioTravelApp.LoginPage"
    NavigationPage.HasBackButton="False"
    Shell.NavBarIsVisible="False"
    Title="Đăng nhập">

    <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">

        <Label Text="Đăng nhập" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>

        <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email"/>

        <Entry x:Name="PasswordEntry" Placeholder="Mật khẩu" IsPassword="True"/>

        <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False" HorizontalOptions="Center"/>

        <Button Text="Đăng nhập" CornerRadius="10" HeightRequest="48" Clicked="OnLoginClicked"/>

        <Button
        Text="Chưa có tài khoản? Đăng ký"
        BackgroundColor="Transparent"
        TextColor="Gray"
        Clicked="OnGoToRegisterClicked"/>

    </VerticalStackLayout>
</ContentPage>
