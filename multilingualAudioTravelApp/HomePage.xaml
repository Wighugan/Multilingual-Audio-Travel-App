<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="multilingualAudioTravelApp.HomePage"
    >


    <Grid RowDefinitions="Auto,Auto,*">

        <!-- 🔵 APP BAR -->
        <Grid
            BackgroundColor="#0A5BD3"
            Padding="16"
            ColumnDefinitions="Auto,*">

            <Image
                Source="search.png"
                WidthRequest="22"
                HeightRequest="22"
                VerticalOptions="Center"/>

            <SearchBar
    Grid.Column="1"
    x:Name="SearchBar"
    Placeholder="Tìm quán ăn..."
    PlaceholderColor="#CCFFFFFF"
    TextColor="White"
    BackgroundColor="Transparent"
    TextChanged="OnSearchTextChanged"
    SearchButtonPressed="OnSearchButtonPressed"
    Margin="8,0,0,0"/>
        </Grid>

        <!-- TABS -->
        <Grid
            Grid.Row="1"
            ColumnDefinitions="*,*,*"
            Padding="12,8">

            <Label Text="Tất cả"
                   TextColor="#0A5BD3"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
            <Label Grid.Column="1"
                   Text="Gần đây"
                   TextColor="Gray"
                   HorizontalOptions="Center"/>
            <Label Grid.Column="2"
                   Text="Nổi bật"
                   TextColor="Gray"
                   HorizontalOptions="Center"/>
        </Grid>
        
        
        
        
        <!-- DANH SÁCH QUÁN -->
        <CollectionView
            Grid.Row="2"
            x:Name="PoiCollection"
            ItemsLayout="VerticalGrid, 2"
            Margin="12"
            SelectionMode="Single"
            SelectionChanged="OnPoiSelected">

            <CollectionView.EmptyView>
                <Label
                    Text="Không tìm thấy quán nào"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    TextColor="Gray"
                    Margin="0,40"/>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="6" CornerRadius="20" HasShadow="False" Padding="0">
                        <Grid HeightRequest="230">

                            <Image Source="{Binding Image}" Aspect="AspectFill"/>
                            <BoxView BackgroundColor="#50000000"/>
                            <Image
                                Source="heart.png"
                                WidthRequest="20" HeightRequest="20"
                                Margin="12"
                                HorizontalOptions="Start"
                                VerticalOptions="Start"/>

                            <StackLayout Padding="12" VerticalOptions="End">
                                <Label
                                    Text="{Binding Name}"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="14"/>
                                <Label
                                    Text="{Binding ShortDescription}"
                                    TextColor="White"
                                    FontSize="11"
                                    MaxLines="2"
                                    LineBreakMode="TailTruncation"/>
                            </StackLayout>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>
