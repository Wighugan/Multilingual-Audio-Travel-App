<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="multilingualAudioTravelApp.LoginPage"
    NavigationPage.HasBackButton="False"
    Shell.NavBarIsVisible="False"
    Title="Đăng nhập">

    <VerticalStackLayout
        Padding="24"
        Spacing="16"
        VerticalOptions="Center">

        <Label
            Text="Đăng nhập"
            FontSize="28"
            FontAttributes="Bold"
            HorizontalOptions="Center"/>

        <Entry
            Placeholder="Email"
            Keyboard="Email"/>

        <Entry
            Placeholder="Mật khẩu"
            IsPassword="True"/>

        <Button
            Text="Đăng nhập"
            CornerRadius="10"
            HeightRequest="48"
            Clicked="OnLoginClicked"/>

    </VerticalStackLayout>

</ContentPage>
