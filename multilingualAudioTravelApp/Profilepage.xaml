<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="multilingualAudioTravelApp.ProfilePage"
    xmlns:lang="clr-namespace:multilingualAudioTravelApp.Languages"
    Title="{x:Static lang:AppStrings.Profile}">
    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" Padding="0,0,8,0" VerticalOptions="Center">
            <Label Text="{x:Static lang:AppStrings.Profile}"
                   FontSize="20" FontAttributes="Bold"
                   VerticalOptions="Center" Margin="16,0,0,0"/>
            <Switch Grid.Column="1"
                    IsToggled="{Binding IsDarkMode}"
                    VerticalOptions="Center"/>
        </Grid>
    </Shell.TitleView>
    <Grid>

        <!-- NỘI DUNG CHÍNH -->
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- Avatar + Welcome -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="8">

                    <Frame
                        WidthRequest="100"
                        HeightRequest="100"
                        CornerRadius="50"
                        Padding="0"
                        BackgroundColor="#E0E0E0"
                        HasShadow="False"
                        HorizontalOptions="Center">
                        <Label
                            Text="{Binding UserInitial}"
                            FontSize="36"
                            FontAttributes="Bold"
                            TextColor="Gray"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>
                    </Frame>

                    <Label
                        Text="{Binding WelcomeText}"
                        FontSize="18"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"/>

                    <Label
                        Text="{Binding UserEmail}"
                        FontSize="13"
                        TextColor="Gray"
                        HorizontalOptions="Center"/>

                </VerticalStackLayout>
                <!-- ── BANNER NÂNG CẤP PREMIUM ── -->
                <Frame BackgroundColor="#FFF3E0" CornerRadius="16"
                       Padding="16" HasShadow="False"
                       BorderColor="#FFCC80">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPremiumBannerTapped"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Label Text="💎" FontSize="32" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label x:Name="PremiumBannerTitleLabel" Text="" FontSize="15" FontAttributes="Bold" TextColor="Black"/>
                            <Label x:Name="PremiumBannerSubtitleLabel" Text="" FontSize="12" TextColor="Black"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›"
                               FontSize="22" TextColor="#E65100"
                               VerticalOptions="Center"/>
                    </Grid>
                </Frame>

                <!-- Dark mode --><!--
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label Text="{x:Static lang:AppStrings.Darkmode}" FontSize="16"/>
                        <Label Text="On/Off" FontSize="12" TextColor="Gray"/>
                    </VerticalStackLayout>
                    <Switch Grid.Column="1" IsToggled="{Binding IsDarkMode}"/>
                </Grid>-->

                <BoxView HeightRequest="1" BackgroundColor="#DDDDDD"/>

                <!-- Menu -->
                <CollectionView
                    ItemsSource="{Binding ProfileMenus}"
                    SelectionMode="Single"
                    SelectionChanged="OnMenuSelected">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,12" ColumnDefinitions="*,Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold"/>
                                    <Label Text="{Binding Description}" FontSize="13" TextColor="Gray"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="›" FontSize="20" VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <BoxView HeightRequest="1" BackgroundColor="#DDDDDD"/>

                <Button
                    Text="{x:Static lang:AppStrings.BtnLogout}"
                    BackgroundColor="#D32F2F"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Margin="0,30,0,10"
                    Clicked="OnLogoutClicked"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ===== POPUP FEEDBACK ===== -->
        <Grid
            x:Name="FeedbackOverlay"
            IsVisible="False"
            BackgroundColor="#80000000">

            <Frame
                BackgroundColor="White"
                CornerRadius="20"
                Padding="24"
                Margin="24"
                VerticalOptions="Center"
                HasShadow="True">

                <VerticalStackLayout Spacing="16">

                    <Label
                        Text="Đánh giá &amp; Góp ý"
                        FontSize="18"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"/>

                    <!-- 5 SAO -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                        <Label x:Name="S1" Text="☆" FontSize="44" TextColor="#FFC107">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="1"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label x:Name="S2" Text="☆" FontSize="44" TextColor="#FFC107">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="2"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label x:Name="S3" Text="☆" FontSize="44" TextColor="#FFC107">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="3"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label x:Name="S4" Text="☆" FontSize="44" TextColor="#FFC107">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="4"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label x:Name="S5" Text="☆" FontSize="44" TextColor="#FFC107">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="5"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    

                    <!-- Ô nhập góp ý -->
                    <Border StrokeThickness="1" Stroke="#DDDDDD" Padding="4">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Editor
                            x:Name="FeedbackEditor"
                            Placeholder="Nhập góp ý của bạn (tùy chọn)..."
                            HeightRequest="100"
                            MaxLength="300"/>
                    </Border>

                    <!-- Thông báo lỗi -->
                    <Label
                        x:Name="FeedbackErrorLabel"
                        Text="Vui lòng chọn số sao!"
                        TextColor="Red"
                        FontSize="13"
                        IsVisible="False"
                        HorizontalOptions="Center"/>

                    <!-- NÚT HỦY + GỬI -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button
                            Text="Hủy"
                            BackgroundColor="#EEEEEE"
                            TextColor="Gray"
                            CornerRadius="10"
                            HeightRequest="44"
                            Clicked="OnFeedbackCancelClicked"/>
                        <Button
                            Grid.Column="1"
                            Text="Gửi"
                            BackgroundColor="#2196F3"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="44"
                            Clicked="OnFeedbackSubmitClicked"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>
